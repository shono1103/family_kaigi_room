# Docker Compose (dev PostgreSQL)
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=hogehoge-ticket-platform-postgres-dev
POSTGRES_RESTART_POLICY=unless-stopped

POSTGRES_HOST=localhost
POSTGRES_DB=hogehoge_ticket_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

TZ=Asia/Tokyo

# App / Prisma
# 必要に応じて上の POSTGRES_* 設定に合わせて手動で変更してください
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hogehoge_ticket_platform?schema=public"
