# =========================
# Development
# =========================

# Docker Compose (dev PostgreSQL)
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=hogehoge-ticket-platform-postgres-dev
POSTGRES_RESTART_POLICY=unless-stopped

POSTGRES_HOST=localhost
POSTGRES_DB=hogehoge_ticket_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

TZ=Asia/Tokyo

# App / Prisma
# 必要に応じて上の POSTGRES_* 設定に合わせて手動で変更してください
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hogehoge_ticket_platform?schema=public"

# Initial admin user for scripts/init.ts
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="admin"
INITIAL_ADMIN_SYMBOL_PRIVATE_KEY=

# Symbol
# 使用するネットワーク（このプロジェクトの想定は testnet）
SYMBOL_NETWORK=testnet
# カンマ区切りの優先順リスト
SYMBOL_TESTNET_NODE_URL_LIST=https://001-sai-dual.symboltest.net:3001,https://201-sai-dual.symboltest.net:3001,https://sym-test-03.opening-line.jp:3001
SYMBOL_MAINNET_NODE_URL_LIST=https://xym.jp1.node.leywapool.com:3001,https://0.xym.stakeme.tokyo:3001,https://xymtokyo.harvest-node.net:3001
# ノードHTTPリクエストのデフォルトタイムアウト（ミリ秒）
SYMBOL_HTTP_TIMEOUT_MS=5000
# トランザクション状態確認のポーリング間隔（ミリ秒）
SYMBOL_POLL_INTERVAL_MS=3000
# トランザクション状態確認の最大待機時間（ミリ秒）
SYMBOL_POLL_TIMEOUT_MS=120000

# =========================
# Test / Integration
# =========================

# Docker Compose (test PostgreSQL)
POSTGRES_TEST_CONTAINER_NAME=hogehoge-ticket-platform-postgres-test
POSTGRES_TEST_RESTART_POLICY=unless-stopped
POSTGRES_TEST_DB=hogehoge_ticket_platform_test
POSTGRES_TEST_USER=postgres
POSTGRES_TEST_PASSWORD=postgres
POSTGRES_TEST_PORT=5433

# Prisma (integration test)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/hogehoge_ticket_platform_test?schema=public"

# Symbol (integration test)
TEST_SYMBOL_NETWORK=testnet
TEST_SYMBOL_TESTNET_NODE_URL_LIST=https://001-sai-dual.symboltest.net:3001
TEST_SYMBOL_MAINNET_NODE_URL_LIST=
TEST_SYMBOL_ISSUER_PRIVATE_KEY=
TEST_SYMBOL_TICKET_METADATA_SEED=ticket:info/v1

# Transaction defaults (integration test)
TEST_AGGREGATE_TYPE=aggregate_complete_transaction_v3
TEST_FEE_MULTIPLIER=100
TEST_DEADLINE_HOURS=2
